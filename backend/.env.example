# Environment Variables
# Copy this file to .env and fill in the values

# Supabase PostgreSQL connection string
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?sslmode=require
DATABASE_URL=

# Secret key for signing JWT tokens (use a long random string)
JWT_SECRET=

# Node environment
NODE_ENV=development

# Frontend URL — required in production for CORS
# Set this to your deployed frontend URL on Render / GitHub Pages
# Example: https://reimburse-frontend.onrender.com
FRONTEND_URL=http://localhost:3000
